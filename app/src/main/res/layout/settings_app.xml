<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:paddingHorizontal="32dp"
    android:layout_height="match_parent">

    <!-- Title -->
    <TextView
        android:id="@+id/tvSettingsTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Strava Profile Settings"
        android:textSize="20sp"
        android:textStyle="bold"
        android:fontFamily="@font/atkinsonhyperlegiblenext_variable" />

    <!-- Spacer -->
    <View
        android:layout_width="match_parent"
        android:layout_height="16dp" />

    <!-- Profile URL Input -->
    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/tilProfileUrl"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Strava Profile URL"
        app:boxCornerRadiusBottomEnd="12dp"
        app:boxCornerRadiusBottomStart="12dp"
        app:boxCornerRadiusTopEnd="12dp"
        app:boxCornerRadiusTopStart="12dp"
        app:cursorColor="?attr/colorAccent"
        app:boxStrokeColor="@color/textbox_stroke"
        app:endIconMode="clear_text">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etProfileUrl"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="textUri"
            android:maxLines="1" />

    </com.google.android.material.textfield.TextInputLayout>

    <!-- Helper Text -->
    <TextView
        android:id="@+id/tvUrlHelper"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Example: https://www.strava.com/athletes/123456"
        android:textSize="12sp"
        android:textColor="?attr/colorOnSurfaceVariant"
        android:layout_marginTop="4dp" />

    <!-- Buttons -->
    <LinearLayout
        android:id="@+id/actionBtn_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="end"
        android:layout_marginTop="12dp"
        android:visibility="visible"
        android:animateLayoutChanges="true">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCancel"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:backgroundTint="@color/transparent"
            app:strokeColor="@color/black_white"
            android:alpha="0.7"
            app:strokeWidth="1dp"
            app:cornerRadius="12dp"
            android:layout_marginEnd="6dp"
            android:text="Cancel" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSave"
            style="@style/Widget.Material3.Button"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="?attr/colorOnPrimary"
            android:backgroundTint="@color/white_black"
            app:cornerRadius="12dp"
            app:strokeColor="@color/black_white"
            app:strokeWidth="1dp"
            android:layout_marginStart="6dp"
            android:text="Save" />

    </LinearLayout>

    <!-- Graph Y Axis -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingVertical="8dp"
        android:layout_marginTop="12dp">

        <LinearLayout
            android:id="@+id/click_TextContainer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_alignParentStart="true">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:alpha="0.8"
                android:fontFamily="@font/atkinsonhyperlegiblenext_medium"
                android:text="Configure Strava button"
                android:textColor="@color/black_white"
                android:textSize="16sp"/>

            <TextView
                android:id="@+id/tvClick_sub"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:alpha="0.65"
                android:fontFamily="@font/atkinsonhyperlegiblenext_regular"
                android:text="Opens Strava Profile"
                android:textColor="@color/black_white"
                android:textSize="14sp"/>
        </LinearLayout>

        <com.google.android.material.materialswitch.MaterialSwitch
            android:id="@+id/switch_longshortClick"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:enabled="true"
            android:checked="true"
            app:thumbTint="@color/switch_thumb_colors"
            app:trackTint="@color/switch_track_colors"/>

    </RelativeLayout>

</LinearLayout>