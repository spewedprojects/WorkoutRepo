<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:paddingHorizontal="32dp"
    android:requiresFadingEdge="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingVertical="4dp">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_alignParentStart="true"
                android:layout_centerVertical="true">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:alpha="0.8"
                    android:fontFamily="@font/atkinsonhyperlegiblenext_medium"
                    android:text="Enable Starva"
                    android:textColor="@color/black_white"
                    android:textSize="16sp"/>

                <TextView
                    android:id="@+id/tvenablestrava_sub"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:alpha="0.65"
                    android:fontFamily="@font/atkinsonhyperlegiblenext_regular"
                    android:text="Strava feature enabled"
                    android:textColor="@color/black_white"
                    android:textSize="14sp"/>
            </LinearLayout>

            <com.google.android.material.materialswitch.MaterialSwitch
                android:id="@+id/switch_enablestrava"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerVertical="true"
                android:layout_alignParentEnd="true"
                android:layout_marginStart="8dp"
                android:enabled="true"
                android:checked="true"
                app:thumbTint="@color/switch_thumb_colors"
                app:trackTint="@color/switch_track_colors_strava"/>

        </RelativeLayout>

        <LinearLayout
            android:id="@+id/strava_settings_container"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="visible">
            <!-- Title -->
            <TextView
                android:id="@+id/tvSettingsTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Strava Profile Settings"
                android:textSize="20sp"
                android:textStyle="bold"
                android:paddingBottom="6dp"
                android:fontFamily="@font/atkinsonhyperlegiblenext_variable" />

            <!-- Profile URL Input -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilProfileUrl"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Strava Profile URL"
                app:boxCornerRadiusBottomEnd="12dp"
                app:boxCornerRadiusBottomStart="12dp"
                app:boxCornerRadiusTopEnd="12dp"
                app:boxCornerRadiusTopStart="12dp"
                app:cursorColor="?attr/colorAccent"
                app:boxStrokeColor="@color/textbox_stroke"
                android:saveEnabled="true"
                app:endIconCheckable="true"
                app:endIconDrawable="@drawable/check_24">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etProfileUrl"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textUri"
                    android:maxLines="1"
                    android:imeOptions="actionDone"
                    android:saveEnabled="true"/>

            </com.google.android.material.textfield.TextInputLayout>

            <!-- Helper Text -->
            <TextView
                android:id="@+id/tvUrlHelper"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Example: https://www.strava.com/athletes/123456"
                android:textSize="12sp"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:layout_marginTop="4dp" />

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingVertical="4dp"
                android:layout_marginTop="12dp">

                <LinearLayout
                    android:id="@+id/click_TextContainer"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_alignParentStart="true">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:alpha="0.8"
                        android:fontFamily="@font/atkinsonhyperlegiblenext_medium"
                        android:text="Configure Strava button"
                        android:textColor="@color/black_white"
                        android:textSize="16sp"/>

                    <TextView
                        android:id="@+id/tvClick_sub"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:alpha="0.65"
                        android:fontFamily="@font/atkinsonhyperlegiblenext_regular"
                        android:text="Opens full Strava Archive"
                        android:textColor="@color/black_white"
                        android:textSize="14sp"/>
                </LinearLayout>

                <com.google.android.material.materialswitch.MaterialSwitch
                    android:id="@+id/switch_longshortClick"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:enabled="true"
                    android:checked="true"
                    app:thumbTint="@color/switch_thumb_colors"
                    app:trackTint="@color/switch_track_colors"/>

            </RelativeLayout>

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingVertical="4dp">

                <LinearLayout
                    android:id="@+id/click_autorefresh"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_alignParentStart="true"
                    android:layout_centerVertical="true">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:alpha="0.8"
                        android:fontFamily="@font/atkinsonhyperlegiblenext_medium"
                        android:text="Enable Auto refresh data"
                        android:textColor="@color/black_white"
                        android:textSize="16sp"/>

                    <TextView
                        android:id="@+id/tvautorefresh_sub"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:alpha="0.65"
                        android:fontFamily="@font/atkinsonhyperlegiblenext_regular"
                        android:text="Set a custom duration"
                        android:textColor="@color/black_white"
                        android:textSize="14sp"/>
                </LinearLayout>

                <com.google.android.material.materialswitch.MaterialSwitch
                    android:id="@+id/switch_enableautorefresh"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerVertical="true"
                    android:layout_alignParentEnd="true"
                    android:layout_marginStart="12dp"
                    android:enabled="true"
                    android:checked="true"
                    app:thumbTint="@color/switch_thumb_colors"
                    app:trackTint="@color/switch_track_colors"/>

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/tilAutoRefresh"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:boxCornerRadiusBottomEnd="12dp"
                    app:boxCornerRadiusBottomStart="12dp"
                    app:boxCornerRadiusTopEnd="12dp"
                    app:boxCornerRadiusTopStart="12dp"
                    android:layout_toStartOf="@id/switch_enableautorefresh"
                    android:layout_centerVertical="true"
                    app:cursorColor="?attr/colorAccent"
                    android:hint="hrs"
                    app:boxStrokeColor="@color/textbox_stroke"
                    android:visibility="visible"
                    android:saveEnabled="true"
                    android:paddingBottom="4dp">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etAutoRefresh"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textSize="12sp"
                        android:inputType="number"
                        android:textAlignment="center"
                        android:imeOptions="actionDone"
                        android:maxLines="1"
                        android:saveEnabled="true"/>
                </com.google.android.material.textfield.TextInputLayout>

            </RelativeLayout>

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingVertical="4dp"
                android:layout_marginTop="12dp"
                android:visibility="gone">

                <LinearLayout
                    android:id="@+id/ExpImp_Container"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_alignParentStart="true">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:alpha="0.8"
                        android:fontFamily="@font/atkinsonhyperlegiblenext_medium"
                        android:text="Strava Repository"
                        android:textColor="@color/black_white"
                        android:textSize="16sp"/>

                    <TextView
                        android:id="@+id/tvExpImp_sub"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:alpha="0.65"
                        android:fontFamily="@font/atkinsonhyperlegiblenext_regular"
                        android:text="Export/Import Strava Data"
                        android:textColor="@color/black_white"
                        android:textSize="14sp"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:elevation="2dp"
                    android:orientation="horizontal"
                    android:paddingHorizontal="6dp"
                    android:layout_marginVertical="2dp"
                    android:layout_marginHorizontal="2dp"
                    android:background="@drawable/rounded_corners">

                    <ImageButton
                        android:id="@+id/Exp_S_Data"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:padding="9dp"
                        android:alpha="0.7"
                        android:src="@drawable/download_icon_inverse"
                        android:backgroundTint="@color/transparent"
                        android:tooltipText="Export/Save the data to storage"/>

                    <com.google.android.material.divider.MaterialDivider
                        android:layout_width="1dp"
                        android:layout_height="match_parent"
                        android:layout_margin="6dp"/>

                    <ImageButton
                        android:id="@+id/Imp_S_Data"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:padding="9dp"
                        android:alpha="0.7"
                        android:src="@drawable/download_icon"
                        android:backgroundTint="@color/transparent"
                        android:tooltipText="Import/Load old data to storage"/>
                </LinearLayout>

            </RelativeLayout>

        </LinearLayout>

    </LinearLayout>

</androidx.core.widget.NestedScrollView>