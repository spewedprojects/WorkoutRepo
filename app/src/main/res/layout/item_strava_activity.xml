<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginVertical="6dp"
    android:layout_marginHorizontal="22dp"
    app:cardBackgroundColor="?attr/colorPrimaryVariant"
    app:cardCornerRadius="10dp"
    app:cardElevation="2dp"
    app:strokeWidth="1.5dp"
    app:strokeColor="#fc4c02">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Activity Title -->
        <TextView
            android:id="@+id/tvActivityTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Morning Ride"
            android:textStyle="bold"
            android:textSize="17sp"
            android:paddingEnd="6dp"
            android:fontFamily="@font/atkinsonhyperlegiblenext_regular"
            android:letterSpacing="0.0"
            android:textColor="@color/black_white"
            android:maxLines="1"
            android:ellipsize="end"
            android:layout_toStartOf="@id/tvActivityDate"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@id/tvActivityTitle"
            android:layout_alignParentStart="true"
            android:layout_alignParentEnd="true"
            android:layout_marginTop="4dp"
            android:paddingStart="2dp"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/ivActivityIcon"
                android:layout_width="20dp"
                android:layout_height="wrap_content"
                android:src="@drawable/strava_roadbike" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="12dp">

                <!-- Activity Summary -->
                <TextView
                    android:id="@+id/tvActivitySummary"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:alpha="0.75"
                    android:ellipsize="end"
                    android:fontFamily="@font/inter"
                    android:maxLines="4"
                    android:textStyle="italic"
                    android:text="Tap to load activity details"
                    android:textColor="@color/black_white"
                    android:textSize="13.5sp"/>

                <!-- Activity Details -->
                <TextView
                    android:id="@+id/tvActivityDetails"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:alpha="0.75"
                    android:ellipsize="end"
                    android:fontFamily="@font/atkinsonhyperlegiblenext_regular"
                    android:maxLines="1"
                    android:text="25.3 km • 1h 05m • 210w • 115bpm • 120mt"
                    android:textColor="@color/black_white"
                    android:textSize="14sp" />

            </LinearLayout>

        </LinearLayout>

        <!-- Activity Date -->
        <TextView
            android:id="@+id/tvActivityDate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="15 Feb 2026"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="@color/black_white"
            android:fontFamily="@font/atkinsonhyperlegiblenext_regular"
            android:alpha="0.75"
            android:layout_marginTop="3dp"
            android:gravity="end"
            android:paddingBottom="4dp"
            android:layout_alignParentEnd="true"
            android:layout_alignBottom="@id/tvActivityTitle"/>

    </RelativeLayout>

</com.google.android.material.card.MaterialCardView>