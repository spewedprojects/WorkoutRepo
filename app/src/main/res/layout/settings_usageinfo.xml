<?xml version="1.0" encoding="utf-8"?>

<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:paddingHorizontal="32dp">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">
            <!-- TITLE -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Usage Guide"
                android:textSize="20sp"
                android:textStyle="bold"
                android:paddingBottom="12dp"
                android:gravity="start"
                android:layout_alignParentStart="true"
                android:fontFamily="@font/atkinsonhyperlegiblenext_variable"/>

            <!-- Current version info -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:fontFamily="@font/atkinsonhyperlegiblenext_regular"
                android:paddingTop="4dp"
                android:text="@string/app_version" />
        </RelativeLayout>

        <!-- SECTION: SHORTCUTS -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Hidden Shortcuts"
            android:textSize="16sp"
            android:textStyle="bold"
            android:paddingBottom="6dp"
            android:fontFamily="@font/atkinsonhyperlegiblenext_variable"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="• Slide the GitHub icon to reveal the theme switcher\n• Long-press a workout to edit.\n• Tap Save button to save changes."
            android:textSize="14sp"
            android:paddingBottom="12dp"
            android:fontFamily="@font/atkinsonhyperlegiblenext_variable"/>

        <!-- SECTION: WORKOUT RULES -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Workouts"
            android:textSize="16sp"
            android:textStyle="bold"
            android:paddingBottom="6dp"
            android:fontFamily="@font/atkinsonhyperlegiblenext_variable"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="• Each new line is treated as a bullet point\n• Saving automatically applies formatting."
            android:textSize="14sp"
            android:paddingBottom="12dp"
            android:fontFamily="@font/atkinsonhyperlegiblenext_variable"/>

        <!-- SECTION: NOTES RULES -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Notes Formatting"
            android:textSize="16sp"
            android:textStyle="bold"
            android:paddingBottom="6dp"
            android:fontFamily="@font/atkinsonhyperlegiblenext_variable"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingBottom="8dp">

            <com.google.android.material.divider.MaterialDivider
                android:layout_width="1dp"
                android:layout_height="match_parent"
                android:layout_marginEnd="4dp"/>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="match_parent"
                android:orientation="vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:text="**Bold text**"
                    android:textSize="14sp"
                    android:typeface="monospace"
                    android:paddingEnd="8dp"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:text="- item"
                    android:textSize="14sp"
                    android:typeface="monospace"
                    android:paddingEnd="8dp" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:text="-- item"
                    android:textSize="14sp"
                    android:typeface="monospace"
                    android:paddingEnd="8dp" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:text="--- item"
                    android:textSize="14sp"
                    android:typeface="monospace"
                    android:paddingEnd="8dp" />
            </LinearLayout>

            <com.google.android.material.divider.MaterialDivider
                android:layout_width="1dp"
                android:layout_height="match_parent"
                android:layout_marginHorizontal="8dp"/>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="match_parent"
                android:orientation="vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:text="Bold text"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:fontFamily="@font/atkinsonhyperlegiblenext_semibold"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:text="• Main bullet point"
                    android:textSize="14sp"
                    android:fontFamily="@font/atkinsonhyperlegiblenext_variable"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:text="  • Indented bullet point"
                    android:textSize="14sp"
                    android:fontFamily="@font/atkinsonhyperlegiblenext_variable"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:text="     \u25E6 Sub-bullet point"
                    android:textSize="14sp"
                    android:fontFamily="@font/atkinsonhyperlegiblenext_variable"/>
            </LinearLayout>

        </LinearLayout>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>