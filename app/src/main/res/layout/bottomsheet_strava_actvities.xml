<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:id="@+id/bottom_sheet_root"
    android:background="@drawable/bg_bottomsheet_rounded"
    android:fitsSystemWindows="false"
    android:elevation="20dp"
    android:clipToPadding="false"
    android:clipChildren="true"
    android:layout_marginTop="56dp"
    android:layout_marginHorizontal="56dp">

    <com.google.android.material.bottomsheet.BottomSheetDragHandleView
        android:id="@+id/Sdrag_handle"
        android:layout_width="wrap_content"
        android:layout_height="14dp"
        android:elevation="4dp"
        android:padding="0dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>

    <RelativeLayout
        android:id="@+id/header_container"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:layout_marginTop="24dp"
        android:paddingHorizontal="24dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Strava Activities today"
            android:textSize="18sp"
            android:textStyle="bold"
            android:fontFamily="@font/atkinsonhyperlegiblenext_regular"
            android:gravity="center"
            android:textColor="@color/black_white"
            android:alpha="0.90"
            android:elevation="1dp"
            android:layout_alignParentStart="true"/>

        <TextView
            android:id="@+id/tvSubTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Last synced (not synced yet)"
            android:textSize="13sp"
            android:textStyle="italic"
            android:paddingEnd="8dp"
            android:fontFamily="@font/atkinsonhyperlegiblenext_regular"
            android:gravity="center"
            android:textColor="@color/black_white"
            android:alpha="0.70"
            android:elevation="1dp"
            android:layout_alignParentStart="true"
            android:layout_below="@id/tvTitle"/>

        <ImageButton
            android:id="@+id/refresh_btn"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:padding="0dp"
            android:alpha="0.7"
            android:background="@color/transparent"
            android:src="@drawable/outline_autorenew_24"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"/>
    </RelativeLayout>

    <com.google.android.material.progressindicator.CircularProgressIndicator
        android:id="@+id/progressBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:visibility="gone"
        android:indeterminateTint="#80fc4c02"
        android:indeterminateBehavior="cycle"
        app:layout_constraintBottom_toTopOf="@id/rvActivities"
        app:layout_constraintTop_toBottomOf="@id/header_container"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvActivities"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintHeight_max="600dp"
        android:clipToPadding="false"
        android:requiresFadingEdge="vertical"
        android:layout_marginBottom="28dp"
        app:layout_constraintTop_toBottomOf="@id/header_container"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>