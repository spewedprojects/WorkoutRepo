add_routine_ui.xml:
<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:id="@+id/add_routine_btns">

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent">

        <ImageButton
			android:id="@+id/addBlank_btn"
            android:layout_width="180dp"
            android:layout_height="180dp"
            android:layout_margin="20dp"
            android:src="@drawable/add_500dp_large"
            android:background="@drawable/round_button_bg"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:textSize="15sp"
            android:letterSpacing="0.04"
            android:text="Add a blank routine"
            android:fontFamily="@font/atkinsonhyperlegiblenext_regular"
            android:textStyle="italic"/>

        <Button
            android:id="@+id/import_btn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="60dp"
            android:paddingHorizontal="24dp"
            android:paddingVertical="14dp"
            android:text="Import Routine"
            android:fontFamily="@font/atkinsonhyperlegiblenext_regular"
            android:textSize="18sp"
            android:textStyle="bold|italic"
            android:letterSpacing="0.04"
            app:strokeColor="?attr/colorOnSurface"
            app:strokeWidth="1dp"
            android:backgroundTint="?attr/colorPrimaryVariant"
            app:cornerRadius="10dp"/>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>


card_week.xml:
<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/cardViewWeek"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:layout_marginHorizontal="30dp"
    android:layout_marginVertical="4dp"
    app:cardCornerRadius="12dp"
    app:strokeWidth="2dp"
    app:strokeColor="@color/success_green"
    app:cardElevation="2dp"
    app:cardBackgroundColor="?attr/colorPrimaryVariant"
    android:longClickable="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <TextView
            android:id="@+id/weekDay"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="22dp"
            android:layout_marginBottom="8dp"
            android:layout_marginHorizontal="25dp"
            android:fontFamily="@font/atkinsonhyperlegiblenext_regular"
            android:textStyle="bold"
            android:text="MONDAY"
            android:textColor="?attr/colorOnPrimary"
            android:textSize="40sp"
            android:letterSpacing="0.04"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintVertical_bias="0"
            app:layout_constraintHorizontal_bias="0.5" />

        <TextView
            android:id="@+id/workoutType"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="8dp"
            android:layout_marginHorizontal="25dp"
            android:paddingBottom="16dp"
            android:clickable="false"
            android:cursorVisible="false"
            android:filterTouchesWhenObscured="false"
            android:focusable="false"
            android:focusableInTouchMode="true"
            android:fontFamily="@font/atkinsonhyperlegiblenext_italic"
            android:textStyle="bold"
            android:inputType="text"
            android:longClickable="true"
            android:text="(Pre-Squat day prep)"
            android:textColor="?attr/colorAccent"
            android:textSize="24sp"
            android:letterSpacing="0.04"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/weekDay"
            app:layout_constraintVertical_bias="0"/>

        <androidx.core.widget.NestedScrollView
            android:id="@+id/scrollView"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/workoutType"
            app:layout_constraintBottom_toTopOf="@id/notesDivider">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <TextView
                    android:id="@+id/major"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="24dp"
                    android:layout_marginVertical="8dp"
                    android:text="Major:"
                    android:textSize="22sp"
                    android:fontFamily="@font/atkinsonhyperlegiblenext_medium"
                    android:textColor="?attr/colorAccent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toTopOf="@id/workoutsMajor"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintHorizontal_bias="0"
                    app:layout_constraintVertical_bias="0"
                    app:layout_constraintVertical_chainStyle="packed"/>

                <TextView
                    android:id="@+id/workoutsMajor"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="24dp"
                    android:layout_marginBottom="20dp"
                    android:filterTouchesWhenObscured="false"
                    android:focusableInTouchMode="true"
                    android:fontFamily="@font/atkinsonhyperlegiblenext_medium"
                    android:text="• Quarter squats\n• Isometrics\n• Weighted Jumps\n• Weighted single leg squats"
                    android:textColor="?attr/colorOnPrimary"
                    android:textSize="20sp"
                    android:longClickable="true"
                    android:gravity="start"
                    app:layout_constraintTop_toBottomOf="@id/major"
                    app:layout_constraintBottom_toTopOf="@id/minor"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintVertical_bias="0"
                    app:layout_constraintVertical_chainStyle="packed"/>

                <TextView
                    android:id="@+id/minor"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="24dp"
                    android:layout_marginVertical="8dp"
                    android:text="Minor:"
                    android:textSize="22sp"
                    android:fontFamily="@font/atkinsonhyperlegiblenext_medium"
                    android:textColor="?attr/colorAccent"
                    app:layout_constraintTop_toBottomOf="@id/workoutsMajor"
                    app:layout_constraintBottom_toTopOf="@id/workoutsMinor"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintVertical_bias="0"
                    app:layout_constraintHorizontal_bias="0"/>

                <TextView
                    android:id="@+id/workoutsMinor"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="24dp"
                    android:layout_marginBottom="12dp"
                    android:filterTouchesWhenObscured="false"
                    android:focusableInTouchMode="true"
                    android:fontFamily="@font/atkinsonhyperlegiblenext_medium"
                    android:text="• Banded warm-ups\n• Jumps\n• Pull-ups\n• Dips"
                    android:textColor="?attr/colorOnPrimary"
                    android:textSize="20sp"
                    android:longClickable="true"
                    android:gravity="start"
                    app:layout_constraintTop_toBottomOf="@id/minor"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintVertical_bias="0"/>
            </androidx.constraintlayout.widget.ConstraintLayout>
        </androidx.core.widget.NestedScrollView>

        <com.google.android.material.divider.MaterialDivider
            android:id="@+id/notesDivider"
            android:layout_width="match_parent"
            android:layout_height="2dp"
            app:layout_constraintBottom_toTopOf="@id/notesContainer"
            app:layout_constraintTop_toBottomOf="@id/scrollView"/>

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/notesContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:layout_constraintTop_toBottomOf="@id/notesDivider"
            app:layout_constraintBottom_toBottomOf="parent">

            <TextView
                android:id="@+id/notes"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="24dp"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="4dp"
                android:text="Notes:"
                android:textSize="18sp"
                android:fontFamily="@font/atkinsonhyperlegiblenext_medium"
                android:textColor="?attr/colorAccent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toTopOf="@id/notesDetails"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintHorizontal_bias="0"
                app:layout_constraintVertical_bias="0"
                app:layout_constraintVertical_chainStyle="packed"/>

            <TextView
                android:id="@+id/notesDetails"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="24dp"
                android:layout_marginBottom="20dp"
                android:filterTouchesWhenObscured="false"
                android:focusableInTouchMode="true"
                android:fontFamily="@font/atkinsonhyperlegiblenext_italic"
                android:hint="Long tap to add notes"
                android:textColor="?attr/colorAccent"
                android:textSize="16sp"
                android:longClickable="true"
                android:gravity="start"
                app:layout_constraintTop_toBottomOf="@id/notes"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintVertical_bias="0"
                app:layout_constraintVertical_chainStyle="packed"/>
        </androidx.constraintlayout.widget.ConstraintLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>
</com.google.android.material.card.MaterialCardView>


routines_view.xml:
<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:id="@+id/routinesPage"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <LinearLayout
        android:id="@+id/main_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center|top"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/routineId"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Routine A"
            android:textSize="40sp"
            android:layout_marginVertical="20dp"
            android:fontFamily="@font/atkinsonhyperlegiblenext_medium"
            android:textColor="?attr/colorOnSurface"/>

        <View
            android:layout_width="match_parent"
            android:layout_height="5dp"
            android:layout_marginHorizontal="9dp"
            android:background="@drawable/dashed_line"/>

        <TextView
            android:id="@+id/notes"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="24dp"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="4dp"
            android:layout_gravity="start"
            android:text="Notes:"
            android:textSize="18sp"
            android:fontFamily="@font/atkinsonhyperlegiblenext_medium"
            android:textColor="?attr/colorAccent"/>

        <TextView
            android:id="@+id/notesDetails"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="24dp"
            android:layout_marginBottom="20dp"
            android:filterTouchesWhenObscured="false"
            android:focusableInTouchMode="true"
            android:fontFamily="@font/atkinsonhyperlegiblenext_italic"
            android:hint="Long tap to add notes"
            android:textColor="?attr/colorAccent"
            android:textSize="16sp"
            android:longClickable="true"/>
    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_day_items"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toBottomOf="@id/main_container"
        app:layout_constraintBottom_toTopOf="@id/btn_container"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintVertical_bias="0"/>

    <RelativeLayout
        android:id="@+id/btn_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_margin="16dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/apply_routine_btn"
            android:layout_width="wrap_content"
            android:layout_height="52dp"
            android:text="APPLY"
            app:strokeWidth="1dp"
            android:layout_alignParentStart="true"
            app:cornerRadius="8dp"
            android:backgroundTint="?attr/colorPrimaryVariant"/>

        <ImageButton
            android:id="@+id/delete_routine_btn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:padding="5dp"
            android:layout_centerInParent="true"
            android:src="@drawable/delete_icon_24dp"
            android:background="@color/transparent" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/save_routine_btn"
            android:layout_width="wrap_content"
            android:layout_height="52dp"
            android:text="SAVE"
            app:strokeWidth="1dp"
            android:layout_alignParentRight="true"
            app:cornerRadius="8dp"
            android:backgroundTint="?attr/colorPrimaryVariant"/>
    </RelativeLayout>

</androidx.constraintlayout.widget.ConstraintLayout>